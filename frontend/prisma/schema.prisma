datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?   @map("email_verified")
  image         String?
  targetRole    String?     @default("SDE-1") @map("target_role")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  resumes       Resume[]
  roadmaps      Roadmap[]
  interviews    Interview[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resume {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  filename           String
  fileUrl            String?  @map("file_url")
  atsScore           Int      @map("ats_score")
  overallScore       Int      @map("overall_score")
  keywordMatchScore  Int      @map("keyword_match_score")
  sections           Json
  keywordsPresent    Json     @map("keywords_present")
  keywordsMissing    Json     @map("keywords_missing")
  improvements       Json
  analyzedAt         DateTime @default(now()) @map("analyzed_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model Roadmap {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  targetRole String   @map("target_role")
  weeks      Json
  totalXp    Int      @default(0) @map("total_xp")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("roadmaps")
}

model Interview {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  targetRole    String   @map("target_role")
  messages      Json
  score         Int      @default(0)
  questionIndex Int      @default(0) @map("question_index")
  isComplete    Boolean  @default(false) @map("is_complete")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model JobEmbedding {
  id           String                       @id @default(cuid())
  title        String
  company      String
  description  String
  requirements String
  skills       Json
  embedding    Unsupported("vector(1024)")?
  createdAt    DateTime                     @default(now()) @map("created_at")

  @@map("job_embeddings")
}
